{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bifrost",
  "version": "1.0.0",
  "identifier": "watch.bifrost.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bifrost",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": false,
        "resizable": true,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Norse rainbow-bridge security dashboard",
    "longDescription": "Bifrost is a desktop security dashboard that watches over your guardian process like Heimdall watches the rainbow bridge."
  }
}
